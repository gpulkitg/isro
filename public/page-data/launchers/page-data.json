42/pslv_c44.jpg","srcSet":"/static/3db0a955e5e0b32df3901f10385e9742/f836f/pslv_c44.jpg 200w,\n/static/3db0a955e5e0b32df3901f10385e9742/2244e/pslv_c44.jpg 400w,\n/static/3db0a955e5e0b32df3901f10385e9742/14b42/pslv_c44.jpg 800w,\n/static/3db0a955e5e0b32df3901f10385e9742/47498/pslv_c44.jpg 1200w,\n/static/3db0a955e5e0b32df3901f10385e9742/0e329/pslv_c44.jpg 1600w,\n/static/3db0a955e5e0b32df3901f10385e9742/f015b/pslv_c44.jpg 3280w","srcWebp":"/static/3db0a955e5e0b32df3901f10385e9742/58556/pslv_c44.webp","srcSetWebp":"/static/3db0a955e5e0b32df3901f10385e9742/61e93/pslv_c44.webp 200w,\n/static/3db0a955e5e0b32df3901f10385e9742/1f5c5/pslv_c44.webp 400w,\n/static/3db0a955e5e0b32df3901f10385e9742/58556/pslv_c44.webp 800w,\n/static/3db0a955e5e0b32df3901f10385e9742/99238/pslv_c44.webp 1200w,\n/static/3db0a955e5e0b32df3901f10385e9742/7c22d/pslv_c44.webp 1600w,\n/static/3db0a955e5e0b32df3901f10385e9742/8bc70/pslv_c44.webp 3280w","sizes":"(max-width: 800px) 100vw, 800px"}}}},{"title":"GSLV","subtitle":"","description":"Geosynchronous Satellite Launch Vehicle was developed to launch the heavier INSAT class of Geosynchronous satellites into orbit. In its third and final stage, GSLV uses the indigenously developed Cryogenic Upper Stage.","button":"MORE INFO","link":"/launchers/gslv-mk-ii","textPosition":"right","textAlignment":"center","objectFit":"cover","image":{"name":"gslv_f11_gsat_7a","childImageSharp":{"fluid":{"base64":"data:image/jpeg;base64,","aspectRatio":0.6666666666666666,"src":"/static/7f2cb09b622ca22de3d848fcc393d27b/14b42/gslv_f11_gsat_7a.jpg","srcSet":"/static/7f2cb09b622ca22de3d848fcc393d27b/f836f/gslv_f11_gsat_7a.jpg 200w,\n/static/7f2cb09b622ca22de3d848fcc393d27b/2244e/gslv_f11_gsat_7a.jpg 400w,\n/static/7f2cb09b622ca22de3d848fcc393d27b/14b42/gslv_f11_gsat_7a.jpg 800w,\n/static/7f2cb09b622ca22de3d848fcc393d27b/47498/gslv_f11_gsat_7a.jpg 1200w,\n/static/7f2cb09b622ca22de3d848fcc393d27b/0e329/gslv_f11_gsat_7a.jpg 1600w,\n/static/7f2cb09b622ca22de3d848fcc393d27b/5056e/gslv_f11_gsat_7a.jpg 2456w","srcWebp":"/static/7f2cb09b622ca22de3d848fcc393d27b/58556/gslv_f11_gsat_7a.webp","srcSetWebp":"/static/7f2cb09b622ca22de3d848fcc393d27b/61e93/gslv_f11_gsat_7a.webp 200w,\n/static/7f2cb09b622ca22de3d848fcc393d27b/1f5c5/gslv_f11_gsat_7a.webp 400w,\n/static/7f2cb09b622ca22de3d848fcc393d27b/58556/gslv_f11_gsat_7a.webp 800w,\n/static/7f2cb09b622ca22de3d848fcc393d27b/99238/gslv_f11_gsat_7a.webp 1200w,\n/static/7f2cb09b622ca22de3d848fcc393d27b/7c22d/gslv_f11_gsat_7a.webp 1600w,\n/static/7f2cb09b622ca22de3d848fcc393d27b/edbd1/gslv_f11_gsat_7a.webp 2456w","sizes":"(max-width: 800px) 100vw, 800px"}}}},{"title":"Sounding Rockets","subtitle":"","description":"ISRO launches smaller rockets from the Rohini series on suborbital and atmospheric flights for aeronomy and meteorological studies. ATV, ISRO's heaviest sounding rocket, can be used for microgravity experiments and for precursor experiments to characterise new technologies.","button":"MORE INFO","link":"/launchers/sounding-rockets","textPosition":"left","textAlignment":"center","objectFit":"cover","image":{"name":"sounding_rocket","childImageSharp":{"fluid":{"base64":"data:image/jpeg;base64,","aspectRatio":0.6644518272425249,"src":"/static/de9f8a7a653a933b08a4b036eb7830c1/0f3a1/sounding_rocket.jpg","srcSet":"/static/de9f8a7a653a933b08a4b036eb7830c1/f836f/sounding_rocket.jpg 200w,\n/static/de9f8a7a653a933b08a4b036eb7830c1/2244e/sounding_rocket.jpg 400w,\n/static/de9f8a7a653a933b08a4b036eb7830c1/0f3a1/sounding_rocket.jpg 500w","srcWebp":"/static/de9f8a7a653a933b08a4b036eb7830c1/e9589/sounding_rocket.webp","srcSetWebp":"/static/de9f8a7a653a933b08a4b036eb7830c1/61e93/sounding_rocket.webp 200w,\n/static/de9f8a7a653a933b08a4b036eb7830c1/1f5c5/sounding_rocket.webp 400w,\n/static/de9f8a7a653a933b08a4b036eb7830c1/e9589/sounding_rocket.webp 500w","sizes":"(max-width: 500px) 100vw, 500px"}}}}],"textContent1":{"title":"Indian Launch Vehicles","text":"<p>Launchers or Launch Vehicles are used to carry spacecraft to space. India has two operational launchers: <a href=\"/launchers/pslv\">Polar Satellite Launch Vehicle (PSLV)</a> and <a href=\"/launchers/gslv-mk-ii\">Geosynchronous Satellite Launch Vehicle (GSLV)</a></p>\n<p>GSLV with indigenous Cryogenic Upper Stage has enabled the launching up to 2 tonne class of communication satellites. The next variant of GSLV is GSLV Mk III, with indigenous high thrust cryogenic engine and stage, having the capability of launching 4 tonne class of communication satellites.</p>\n"},"listLaunchers":[{"title":"Historic","content":[{"link":"/launchers/slv","text":"SLV"},{"link":"/launchers/aslv","text":"ASLV"}]},{"title":"Operational","content":[{"link":"/launchers/pslv","text":"PSLV"},{"link":"/launchers/gslv-mk-ii","text":"GSLV MK II"},{"link":"/launchers/gslv-mk-iii","text":"GSLV Mk III"},{"link":"/launchers/sounding-rockets","text":"Sounding Rockets"}]},{"title":"Future","content":[{"link":"/launchers/rlv-td","text":"RLV-TD"},{"link":"/launchers/scramjet-engine-td","text":"Scramjet Engine - TD"}]}],"figure":{"image":{"name":"Indian_carrier_rockets","publicURL":"/static/fa32cd9ffe145fd2b236556cee876633/Indian_carrier_rockets.svg"},"caption":""},"textContent2":{"title":"Launch Facilities","text":"<p>In order to achieve high accuracy in placing satellites into their orbits, a combination of accuracy, efficiency, power and immaculate planning are required. ISRO's Launch Vehicle Programme spans numerous centres and employs over 5,000 people.</p>\n<p><a href=\"http://www.vssc.gov.in\">Vikram Sarabhai Space Centre</a>, located in Thiruvananthapuram, is responsible for the design and development of launch vehicles.</p>\n<p><a href=\"http://www.lpsc.gov.in\">Liquid Propulsion Systems Centre</a> and <a href=\"/about/isro-propulsion-complex\">ISRO Propulsion Complex</a>, located at Valiamala and Mahendragiri respectively, develop the liquid and cryogenic stages for these launch vehicles.</p>\n<p><a href=\"/about/satish-dhawan-space-centre-sdsc-shar\">Satish Dhawan Space Centre, SHAR</a>, is the space port of India and is responsible for integration of launchers. It houses two operational launch pads from where all GSLV and PSLV flights take place.</p>\n"}}},"pageContext":{}},
